# ============================================================================
# RoboHire API - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ----------------------------------------------------------------------------
# LLM Provider Configuration
# ----------------------------------------------------------------------------

# LLM Provider: direct, openrouter, openai, google, or kimi
# - direct: auto-selects provider from model prefix (e.g. google/gemini-3-flash → Google API)
#           Lets you mix providers per model env var (LLM_MODEL, LLM_FAST, etc.)
# - openrouter: routes all models through OpenRouter (prefix kept as routing key)
# - openai/google/kimi: forces a single direct provider for all models
LLM_PROVIDER=direct

# LLM Model (prefix/model format)
# In 'direct' mode the prefix selects the provider: google/, openai/, kimi/
# In 'openrouter' mode the prefix is OpenRouter's routing key
# OpenRouter models: google/gemini-2.0-flash, anthropic/claude-3.5-sonnet, openai/gpt-4o
# LLM costs: 
# x-ai/grok-4.1-fast: $0.20/M input tokens, $0.50/M output tokens
# google/gemini-3-pro-preview: $2/M input tokens, $12/M output tokens
# google/gemini-3-flash-preview: $0.50/M input tokens, $3/M output tokens
# openai/gpt-oss-120b: $0.039/M input tokens, $0.19/M output tokens
# x-ai/grok-code-fast-1: $0.20/M input tokens, $1.50/M output tokens
# xiaomi/mimo-v2-flash: $0.09/M input tokens, $0.29/M output tokens
# anthropic/claude-opus-4.5: $5/M input tokens, $25/M output tokens
# z-ai/glm-4.7: $0.40/M input tokens, $1.50/M output tokens
# openai/gpt-5.2: $1.75/M input tokens, $14/M output tokens
# OpenAI models: gpt-5.2-2025-12-11
# Google models: gemini-3-pro-preview, gemini-3-flash-preview
# Kimi (Moonshot) models: kimi-k2.5, kimi-k2-turbo-preview, kimi-k2-thinking, kimi-k2-thinking-turbo
# kimi-k2.5: $0.60/M input (cache miss), $0.10/M input (cache hit), $3.00/M output — 256K context, thinking mode
LLM_MODEL=google/gemini-3-flash-preview

# Fast-path model for synchronous UX-critical tasks like interview prompt generation.
# If not set, those paths may fall back to the slower default LLM_MODEL.
# LLM_FAST=google/gemini-3-flash-preview

# Optional override just for interview prompt generation before room join.
# If not set, RoboHire uses INTERVIEW_PROMPT_MODEL -> LLM_FAST -> LLM_MODEL.
# INTERVIEW_PROMPT_MODEL=

# Pre-Match Filter Model (lightweight, fast model for quick resume screening before full matching)
# If not set, pre-filtering is skipped and all selected resumes go directly to full matching
# Recommended: google/gemini-2.0-flash, xiaomi/mimo-v2-flash, openai/gpt-4o-mini
# LLM_PREMATCH_FILTER=

# Dedicated model for AI resume matching (overrides default LLM_MODEL for matching only)
# Use a fast model for quicker results, or a powerful model for better analysis
# If not set, uses the default LLM_MODEL
# LLM_MATCH_RESUME=

# Matching concurrency — how many resume-match LLM calls run in parallel (default: 5)
# MATCH_CONCURRENCY=5

# ----------------------------------------------------------------------------
# API Keys (add the ones you need based on LLM_PROVIDER)
# ----------------------------------------------------------------------------

# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI API Key (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=your_openai_api_key_here

# Google AI API Key (https://aistudio.google.com/app/apikey)
# GOOGLE_API_KEY=your_google_api_key_here

# Kimi (Moonshot) API Key (https://platform.moonshot.cn)
# KIMI_API_KEY=your_kimi_api_key_here
# KIMI_API_BASE_URL=https://api.moonshot.cn/v1

# ----------------------------------------------------------------------------
# TTS (Text-to-Speech) Configuration
# ----------------------------------------------------------------------------

# TTS Provider: openai, elevenlabs, azure, or none (default: none)
# TTS_PROVIDER=none

# TTS Model (depends on provider)
# OpenAI: tts-1, tts-1-hd
# ElevenLabs: eleven_multilingual_v2, eleven_turbo_v2
# Azure: en-US-JennyNeural
# TTS_MODEL=tts-1

# Voice ID (depends on provider)
# OpenAI voices: alloy, echo, fable, onyx, nova, shimmer
# ElevenLabs: use voice ID from your library
# TTS_VOICE_ID=alloy

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------

# Log Level: DEBUG, INFO, WARN, ERROR (default: INFO)
LOG_LEVEL=INFO

# File Logging: true/false (default: true)
# When enabled, logs are written to JSON Lines files in LOG_DIR
FILE_LOGGING=true

# Log Directory: path to store log files (default: ./logs)
# LOG_DIR=./logs

# ----------------------------------------------------------------------------
# Storage Configuration
# ----------------------------------------------------------------------------

# Document Storage: path to store parsed documents and match results
# Parsed resumes, JDs, and match results are cached here
# DOCUMENT_STORAGE_DIR=./parsed-documents

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------

# PostgreSQL connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/robohire
# For Neon serverless Postgres, use the pooled connection string and append params:
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/robohire?sslmode=require&connect_timeout=15&pool_timeout=15&connection_limit=5

# ----------------------------------------------------------------------------
# Authentication Configuration
# ----------------------------------------------------------------------------

# JWT Secret (generate a strong random string)
JWT_SECRET=your_jwt_secret_here_change_in_production

# JWT Token Expiry (in seconds, default: 7 days)
JWT_EXPIRES_IN=604800

# Session Token Expiry (in seconds, default: 30 days)
SESSION_EXPIRES_IN=2592000

# OAuth Redirect URLs
# OAUTH_CALLBACK_URL: Backend URL where OAuth providers redirect after auth
# FRONTEND_URL: Frontend URL where users are redirected after successful OAuth
OAUTH_CALLBACK_URL=http://localhost:4607
FRONTEND_URL=http://localhost:3607
# Additional frontend origins (comma-separated), useful for previews like *.onrender.com
# FRONTEND_URLS=https://robohire.io,https://www.robohire.io,https://my-preview.onrender.com

# Session cookie options
# COOKIE_SAME_SITE: lax | strict | none (default: lax)
# Use `none` only when frontend/backend are on different top-level domains
# COOKIE_SAME_SITE=none
# COOKIE_DOMAIN=.robohire.io

# OAuth: Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth: GitHub
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# OAuth: LinkedIn
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# ----------------------------------------------------------------------------
# Stripe Payment Configuration
# ----------------------------------------------------------------------------

# Stripe API Keys (https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard > Products)
# Use the price ID (price_xxx), not the product ID (prod_xxx)
# STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
# STRIPE_GROWTH_MONTHLY_PRICE_ID=price_...
# STRIPE_BUSINESS_MONTHLY_PRICE_ID=price_...

# Free trial duration in days (default: 14)
# STRIPE_FREE_TRIAL_DAYS=14

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------

# Server port (Render uses 10000 by default)
# PORT=4607

# Node environment
# NODE_ENV=production

# Recruiter email for invitation emails
RECRUITER_EMAIL=hr@yourcompany.com

# External invitation API (GoHire)
# Recommended: full endpoint URL ending in /instant/instant/v1/invitation
# GOHIRE_INVITATION_API=https://report-agent.gohire.top/instant/instant/v1/invitation

# OpenRouter base URL override
# OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1

# ----------------------------------------------------------------------------
# Demo Account (created by running: npm run db:seed)
# ----------------------------------------------------------------------------
# Email:    demo@robohire.io
# Password: demo1234
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# LLM Pricing Reference (OpenRouter, as of 2026)
# ----------------------------------------------------------------------------
# Model                          | Input (per 1M) | Output (per 1M)
# -------------------------------|----------------|----------------
# google/gemini-2.0-flash        | $0.10          | $0.40
# google/gemini-1.5-pro          | $1.25          | $5.00
# openai/gpt-4o                  | $2.50          | $10.00
# openai/gpt-4o-mini             | $0.15          | $0.60
# anthropic/claude-3.5-sonnet    | $3.00          | $15.00
# anthropic/claude-3-haiku       | $0.25          | $1.25
# x-ai/grok-beta                 | $5.00          | $15.00
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# ATS Integration Configuration
# ----------------------------------------------------------------------------

# Encryption key for ATS credentials at rest (32-byte hex or passphrase)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ATS_ENCRYPTION_KEY=your_encryption_key_here

# ----------------------------------------------------------------------------
# LiveKit Configuration (AI Video Interview)
# ----------------------------------------------------------------------------

# LiveKit Cloud WebSocket URL
# LIVEKIT_URL=wss://your-project.livekit.cloud

# LiveKit API Key and Secret (from LiveKit Cloud dashboard)
# LIVEKIT_API_KEY=your_livekit_api_key
# LIVEKIT_API_SECRET=your_livekit_api_secret

# Backend URL for agent → backend communication (default: http://localhost:4607)
# BACKEND_URL=http://localhost:4607

# ----------------------------------------------------------------------------
# MinIO / Object Storage
# ----------------------------------------------------------------------------

MINIO_ENDPOINT=minio endpoint url
MINIO_ACCESS_KEY=minio access key
MINIO_SECRET_KEY=minio secret key
MINIO_SECURE=false
