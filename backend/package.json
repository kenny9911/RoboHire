{
  "name": "robohire-api-backend",
  "version": "1.0.0",
  "description": "RoboHire API Backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "backfill:resume-summaries": "tsx src/scripts/backfillResumeSummaries.ts",
    "agent:start": "tsx src/interview-worker.ts start",
    "agent:download-files": "tsx src/interview-worker.ts download-files",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1013.0",
    "@google/genai": "^1.47.0",
    "@google/generative-ai": "^0.21.0",
    "@livekit/agents": "^1.0.50",
    "@livekit/agents-plugin-google": "^1.0.50",
    "@livekit/agents-plugin-livekit": "^1.0.50",
    "@livekit/agents-plugin-openai": "^1.0.50",
    "@livekit/agents-plugin-silero": "^1.0.50",
    "@livekit/rtc-node": "^0.13.24",
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.3",
    "canvas": "^3.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.12.39",
    "livekit-server-sdk": "^2.15.0",
    "mammoth": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.67.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-linkedin-oauth2": "^2.0.0",
    "pdf-parse": "^1.1.1",
    "pdf-to-img": "^5.0.0",
    "pdfkit": "^0.18.0",
    "prisma": "^6.9.0",
    "stripe": "^20.3.1",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.4",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
