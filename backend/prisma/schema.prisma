// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     User[]
  teamMembers TeamMember[]
  invitations TeamInvitation[]

  @@index([name])
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      String   @default("member") // member, lead
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
}

model TeamInvitation {
  id        String   @id @default(cuid())
  teamId    String
  email     String
  invitedBy String
  status    String   @default("pending") // pending, accepted, declined
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team    Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter User @relation("TeamInviter", fields: [invitedBy], references: [id])

  @@unique([teamId, email])
  @@index([email])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  phone         String?
  jobTitle      String?
  company       String?
  avatar        String?
  role          String    @default("user") // 'user', 'internal', or 'admin'
  provider      String?   // 'email', 'google', 'github', 'linkedin'
  providerId    String?
  teamId        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Subscription / Stripe
  stripeCustomerId    String?   @unique
  subscriptionTier    String    @default("free") // free, startup, business, custom
  subscriptionStatus  String    @default("active") // active, past_due, canceled
  subscriptionId      String?
  currentPeriodEnd    DateTime?
  trialEnd            DateTime?
  interviewsUsed      Int       @default(0)
  resumeMatchesUsed   Int       @default(0)
  topUpBalance        Float     @default(0)
  customMaxInterviews Int?      // Admin override for max interviews (null = use plan default)
  customMaxMatches    Int?      // Admin override for max matches (null = use plan default)

  team            Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  hiringRequests  HiringRequest[]
  sessions        Session[]
  hiringSessions  HiringSession[]
  apiKeys         ApiKey[]
  usageRecords    ApiUsageRecord[]
  apiRequestLogs  ApiRequestLog[]
  llmCallLogs     LLMCallLog[]
  topUpRecords    TopUpRecord[]
  alipayOrders    AlipayOrder[]
  resumes         Resume[]
  recruiterResumes Resume[]  @relation("ResumeRecruiter")
  adminAdjustmentsReceived  AdminAdjustment[] @relation("AdminAdjustmentsReceived")
  adminAdjustmentsMade      AdminAdjustment[] @relation("AdminAdjustmentsMade")
  atsIntegrations ATSIntegration[]
  jobs            Job[]
  interviews         Interview[]
  interviewDialogTurns InterviewDialogTurn[]
  matchingBatchRuns  MatchingBatchRun[]
  matchingSessions   MatchingSession[]
  activities         UserActivity[]
  resumeVersions     ResumeVersion[]
  interviewRoomConfigVersionsCreated InterviewRoomConfigVersion[] @relation("InterviewRoomConfigVersionsCreated")
  agents             Agent[]
  teamMemberships    TeamMember[]
  teamInvitations    TeamInvitation[] @relation("TeamInviter")
  alexSessions       AgentAlexSession[]
  contacts           Contact[]
  companies          Company[]
  tasksAssigned      Task[]         @relation("TaskAssignee")
  tasksCreated       Task[]         @relation("TaskCreator")
  notifications      Notification[]
  goHireInterviewsAsCandidate GoHireInterview[] @relation("GoHireCandidateUser")
  goHireInterviewsAsRecruiter GoHireInterview[] @relation("GoHireRecruiterUser")

  @@index([email])
  @@index([provider, providerId])
  @@index([teamId])
  @@index([createdAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model HiringRequest {
  id              String   @id @default(cuid())
  userId          String
  title           String
  clientName      String?
  requirements    String   @db.Text
  jobDescription  String?  @db.Text
  status                String   @default("active") // active, paused, closed
  webhookUrl            String?
  intelligenceData      Json?
  intelligenceUpdatedAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidates     Candidate[]
  resumeJobFits  ResumeJobFit[]
  jobs           Job[]
  interviews     Interview[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([userId, createdAt])
}

model Candidate {
  id               String   @id @default(cuid())
  hiringRequestId  String
  name             String
  email            String
  resumeText       String   @db.Text
  matchScore       Int?
  status           String   @default("pending") // pending, screening, interviewed, shortlisted, rejected
  evaluationReport Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  externalAtsId       String?
  externalAtsProvider String?

  hiringRequest HiringRequest @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)
  interviews    Interview[]
  dialogTurns   InterviewDialogTurn[]

  @@index([hiringRequestId])
  @@index([status])
  @@index([email])
  @@index([hiringRequestId, status])
  @@index([hiringRequestId, matchScore])
  @@index([externalAtsId])
}

model HiringSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  messages  Json     @default("[]")
  status    String   @default("active") // active, completed, archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([userId, updatedAt])
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  key         String    @unique
  prefix      String    // First 8 chars for display (rh_xxxx...)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  scopes      String[]  @default(["read", "write"])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageRecords ApiUsageRecord[]
  requestLogs  ApiRequestLog[]

  @@index([key])
  @@index([userId])
}

model ApiUsageRecord {
  id               String   @id @default(cuid())
  userId           String
  apiKeyId         String?
  requestId        String?
  endpoint         String
  method           String
  statusCode       Int      @default(200)
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  cost             Float    @default(0)
  model            String?
  provider         String?
  durationMs       Int      @default(0)
  createdAt        DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([apiKeyId])
  @@index([createdAt])
  @@index([endpoint])
  @@index([userId, createdAt])
  @@index([apiKeyId, createdAt])
}

model ApiRequestLog {
  id               String   @id @default(cuid())
  requestId        String?
  userId           String?
  apiKeyId         String?
  endpoint         String
  method           String
  module           String
  apiName          String
  statusCode       Int      @default(200)
  durationMs       Int      @default(0)
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  llmCalls         Int      @default(0)
  cost             Float    @default(0)
  provider         String?
  model            String?
  ipAddress        String?
  userAgent        String?
  requestPayload   Json?
  responsePayload  Json?
  createdAt        DateTime @default(now())

  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiKey     ApiKey?      @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  llmCallLog LLMCallLog[]

  @@index([requestId])
  @@index([userId])
  @@index([apiKeyId])
  @@index([createdAt])
  @@index([endpoint])
  @@index([module])
  @@index([apiName])
  @@index([provider])
  @@index([model])
  @@index([userId, createdAt])
  @@index([module, createdAt])
  @@index([apiName, createdAt])
}

model LLMCallLog {
  id               String   @id @default(cuid())
  requestId        String?
  apiRequestLogId  String?
  userId           String?
  endpoint         String
  module           String
  status           String   @default("success")
  provider         String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  cost             Float    @default(0)
  durationMs       Int      @default(0)
  requestMessages  Json?
  requestOptions   Json?
  responsePreview  String?  @db.Text
  errorMessage     String?  @db.Text
  createdAt        DateTime @default(now())

  apiRequestLog ApiRequestLog? @relation(fields: [apiRequestLogId], references: [id], onDelete: SetNull)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([apiRequestLogId])
  @@index([userId])
  @@index([createdAt])
  @@index([endpoint])
  @@index([module])
  @@index([provider])
  @@index([model])
  @@index([module, createdAt])
}

model TopUpRecord {
  id                  String   @id @default(cuid())
  userId              String
  stripeSessionId     String   @unique  // Stripe Checkout Session ID for idempotency
  stripePaymentIntent String?  @unique  // Stripe PaymentIntent ID
  amountCents         Int
  amountDollars       Float
  status              String   @default("pending") // pending, completed, failed
  creditedAt          DateTime?
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeSessionId])
  @@index([stripePaymentIntent])
  @@index([userId, createdAt])
}

model AlipayOrder {
  id           String    @id @default(cuid())
  userId       String
  outTradeNo   String    @unique
  tier         String    // starter, growth, business
  amount       Float     // payment amount in CNY
  status       String    @default("pending") // pending, completed, failed, closed
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([outTradeNo])
  @@index([status])
}

model AdminAdjustment {
  id          String   @id @default(cuid())
  userId      String
  adminId     String
  type        String   // "balance", "usage_interview", "usage_match", "subscription"
  amount      Float?
  oldValue    String?
  newValue    String?
  reason      String
  createdAt   DateTime @default(now())

  user  User @relation("AdminAdjustmentsReceived", fields: [userId], references: [id], onDelete: Cascade)
  admin User @relation("AdminAdjustmentsMade", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([adminId])
  @@index([createdAt])
}

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([key])
}

model InterviewRoomConfigVersion {
  id            String   @id @default(cuid())
  versionNumber Int      @unique
  versionLabel  String?
  changeNote    String?  @db.Text
  config        Json
  isActive      Boolean  @default(false)
  activatedAt   DateTime?
  createdAt     DateTime @default(now())
  createdById   String?

  createdByUser User?    @relation("InterviewRoomConfigVersionsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([versionNumber])
  @@index([isActive, createdAt])
  @@index([createdById])
  @@index([createdAt])
}

model Resume {
  id              String    @id @default(cuid())
  userId          String
  recruiterUserId String?
  name            String
  email           String?
  phone           String?
  currentRole     String?
  experienceYears String?
  summary         String?   @db.Text  // AI-generated professional summary
  highlight       String?             // One-line highlight for card display
  resumeText      String    @db.Text
  parsedData      Json?
  insightData     Json?
  jobFitData      Json?
  fileName        String?
  fileSize        Int?
  fileType        String?
  originalFileProvider String?
  originalFileKey      String?
  originalFileName     String?
  originalFileMimeType String?
  originalFileSize     Int?
  originalFileChecksum String?
  originalFileStoredAt DateTime?
  contentHash     String?
  status          String    @default("active")
  source          String    @default("upload")
  tags            String[]  @default([])
  notes           String?   @db.Text
  preferences     Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  recruiterUser   User?     @relation("ResumeRecruiter", fields: [recruiterUserId], references: [id], onDelete: SetNull)
  resumeJobFits   ResumeJobFit[]
  jobMatches      JobMatch[]
  resumeVersions  ResumeVersion[]
  agentCandidates AgentCandidate[]
  tasks           Task[]
  goHireInterviews GoHireInterview[]

  @@unique([userId, contentHash])
  @@index([userId])
  @@index([recruiterUserId])
  @@index([userId, status])
  @@index([userId, status, createdAt])
  @@index([name])
  @@index([contentHash])
  @@index([originalFileKey])
  @@index([createdAt])
}

model ResumeVersion {
  id              String   @id @default(cuid())
  resumeId        String
  userId          String
  versionName     String?
  resumeText      String   @db.Text
  parsedData      Json?
  name            String
  email           String?
  phone           String?
  currentRole     String?
  experienceYears String?
  changeNote      String?
  createdAt       DateTime @default(now())

  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resumeId, createdAt])
  @@index([userId])
}

model ResumeJobFit {
  id               String   @id @default(cuid())
  resumeId         String
  hiringRequestId  String
  fitScore         Int?
  fitGrade         String?
  fitData          Json?
  pipelineStatus   String   @default("matched") // matched, shortlisted, rejected, invited
  invitedAt        DateTime?
  inviteData       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  resume           Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  hiringRequest    HiringRequest  @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)

  @@unique([resumeId, hiringRequestId])
  @@index([resumeId])
  @@index([hiringRequestId])
  @@index([fitScore])
  @@index([pipelineStatus])
  @@index([hiringRequestId, pipelineStatus])
  @@index([hiringRequestId, fitScore])
}

model Job {
  id              String    @id @default(cuid())
  userId          String
  hiringRequestId String?
  title           String
  department      String?
  location        String?
  workType        String?   // remote, hybrid, onsite
  employmentType  String?   // full-time, part-time, contract, internship
  experienceLevel String?   // entry, mid, senior, lead, executive
  education       String?   // 学历要求: high_school, associate, bachelor, master, phd, none
  headcount       Int       @default(1) // 招聘人数
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  String?   @default("USD")
  salaryText      String?   @db.Text  // Free-text salary description, e.g. "base3000+补贴600+绩效1000"
  companyName          String?
  description          String?   @db.Text
  qualifications       String?   @db.Text   // 任职要求
  hardRequirements     String?   @db.Text   // 硬性要求
  niceToHave           String?   @db.Text   // 优先条件 / 加分项
  benefits             String?   @db.Text   // 福利待遇
  requirements         Json?     // { mustHave: [], niceToHave: [] }
  parsedData           Json?     // AI-parsed JD cache
  salaryPeriod         String?   @default("monthly") // monthly, yearly
  locations            Json?     // Array of { country, city }
  interviewMode        String?   @default("standard") // standard, question_bank
  passingScore         Int?      @default(60)  // 20-80
  interviewLanguage    String?   @default("en")
  interviewDuration    Int?      @default(30)  // minutes: 15,30,45,60
  interviewRequirements String?  @db.Text  // 面试要求
  evaluationRules      String?   @db.Text  // 评估规则
  notes                String?   @db.Text  // 内部备注，不展示给候选人
  status               String    @default("draft") // draft, open, paused, closed, filled
  publishedAt     DateTime?
  closedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  hiringRequest     HiringRequest?    @relation(fields: [hiringRequestId], references: [id], onDelete: SetNull)
  jobMatches        JobMatch[]
  matchingSessions  MatchingSession[]
  agents            Agent[]
  alexSession       AgentAlexSession?
  tasks             Task[]
  goHireInterviews  GoHireInterview[]

  @@index([userId])
  @@index([hiringRequestId, updatedAt])
  @@index([status])
  @@index([userId, status])
  @@index([userId, createdAt])
}

model JobMatch {
  id          String    @id @default(cuid())
  jobId       String
  resumeId    String
  score       Int?
  grade       String?   // A+, A, B+, B, C, D, F
  matchData   Json?     // Full ResumeMatchAgent output
  status      String    @default("new") // new, reviewed, shortlisted, applied, rejected, invited
  reviewedAt  DateTime?
  reviewedBy  String?
  appliedAt   DateTime?
  appliedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume      Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([jobId, resumeId])
  @@index([jobId])
  @@index([resumeId])
  @@index([score])
  @@index([status])
  @@index([jobId, score])
}

model Interview {
  id              String    @id @default(cuid())
  userId          String
  jobId           String?
  resumeId        String?
  hiringRequestId String?
  candidateId     String?
  candidateName   String
  candidateEmail  String?
  jobTitle        String?
  jobDescription  String?   @db.Text
  resumeText      String?   @db.Text
  status          String    @default("scheduled") // scheduled, in_progress, completed, cancelled, expired
  type            String    @default("ai_video")  // ai_video, ai_audio, ai_text
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  duration        Int?      // seconds
  accessToken     String?   @unique // unique token for candidate to join
  roomId          String?   // LiveKit room ID
  transcript      Json?     // Array of { role, content, timestamp }
  recordingUrl    String?
  gohireUserId    String?   // GoHire user_id returned from invitation API
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  hiringRequest   HiringRequest?      @relation(fields: [hiringRequestId], references: [id], onDelete: SetNull)
  candidate       Candidate?          @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  evaluation      InterviewEvaluation?
  dialogTurns     InterviewDialogTurn[]
  tasks           Task[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([accessToken])
  @@index([userId, createdAt])
  @@index([hiringRequestId])
  @@index([candidateId])
  @@index([resumeId])
  @@index([gohireUserId])
}

model InterviewDialogTurn {
  id          String   @id @default(cuid())
  interviewId String
  candidateId String?
  userId      String
  role        String
  speakerName String?
  content     String   @db.Text
  timestamp   DateTime
  sequence    Int
  createdAt   DateTime @default(now())

  interview Interview  @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  candidate Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([interviewId, sequence])
  @@index([interviewId, timestamp])
  @@index([candidateId, timestamp])
  @@index([userId, timestamp])
}

model InterviewEvaluation {
  id              String    @id @default(cuid())
  interviewId     String    @unique
  overallScore    Int?
  grade           String?
  verdict         String?   // strong_hire, hire, lean_hire, lean_no_hire, no_hire
  evaluationData  Json?     // Full evaluation agent output
  summary         String?   @db.Text
  strengths       Json?     // string[]
  weaknesses      Json?     // string[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@index([overallScore])
  @@index([verdict])
}

model ATSIntegration {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String   // "greenhouse" | "lever" | "ashby" | "bamboohr" | "workable"
  credentials   String   // encrypted JSON: { apiKey, subdomain, etc. }
  isActive      Boolean  @default(true)
  syncEnabled   Boolean  @default(true)
  lastSyncAt    DateTime?
  config        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  webhookDeliveries WebhookDelivery[]
  syncLogs          ATSSyncLog[]

  @@unique([userId, provider])
  @@index([userId])
}

model ATSSyncLog {
  id              String   @id @default(cuid())
  integrationId   String
  integration     ATSIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  direction       String   // "inbound" | "outbound"
  entityType      String   // "job" | "candidate" | "application"
  entityId        String?
  externalId      String?
  status          String   // "success" | "failed" | "skipped"
  error           String?
  payload         Json?
  createdAt       DateTime @default(now())

  @@index([integrationId])
  @@index([createdAt])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  integrationId   String?
  integration     ATSIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  hiringRequestId String?
  event           String
  url             String
  payload         Json
  status          String   // "pending" | "delivered" | "failed"
  statusCode      Int?
  attempts        Int      @default(0)
  maxAttempts     Int      @default(5)
  lastAttemptAt   DateTime?
  nextRetryAt     DateTime?
  response        String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([status, nextRetryAt])
  @@index([hiringRequestId])
}

model UserActivity {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String
  eventType  String   // "page_view" | "click"
  path       String
  element    String?
  elementTag String?
  metadata   Json?
  timestamp  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, timestamp])
  @@index([sessionId])
  @@index([timestamp])
}

model MatchingBatchRun {
  id              String    @id @default(cuid())
  userId          String
  title           String?
  status          String    @default("running") // running, completed, failed
  config          Json      // { jobIds[], resumeIds[], preFilter?, maxAgents }
  summary         Json?     // { jobs[], peakActiveAgents, sessionIds[] }
  totalJobs       Int       @default(0)
  totalTasks      Int       @default(0)
  completedTasks  Int       @default(0)
  failedTasks     Int       @default(0)
  filteredTasks   Int       @default(0)
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchingSessions MatchingSession[]

  @@index([userId, createdAt])
  @@index([status])
}

model MatchingSession {
  id              String    @id @default(cuid())
  userId          String
  jobId           String
  batchRunId      String?
  title           String?
  status          String    @default("running") // running, completed, failed

  // Configuration snapshot
  config          Json      // { resumeIds[], preFilter: { locations?, jobTypes?, freeText? } }

  // Pre-filter results
  preFilterModel  String?
  preFilterResult Json?     // { passedIds[], excluded: [{ resumeId, reason }], durationMs }

  // Results summary
  totalResumes    Int       @default(0)
  totalFiltered   Int       @default(0)
  totalMatched    Int       @default(0)
  totalFailed     Int       @default(0)
  avgScore        Float?
  topGrade        String?

  // Cost tracking
  totalCost       Float     @default(0)
  totalTokens     Int       @default(0)
  totalLLMCalls   Int       @default(0)

  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  batchRun        MatchingBatchRun? @relation(fields: [batchRunId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([jobId])
  @@index([batchRunId])
}

model Agent {
  id              String    @id @default(cuid())
  userId          String
  name            String
  description     String    // natural-language search criteria
  taskType        String    @default("search") // search, match
  instructions    String?   // user instructions for what the agent should do
  status          String    @default("active") // active, paused, completed
  jobId           String?   // linked job (required for task execution)

  // Search config snapshot
  config          Json?     // { location?, skills[], experienceMin?, experienceMax?, keywords? }

  // Stats
  totalSourced    Int       @default(0)
  totalApproved   Int       @default(0)
  totalRejected   Int       @default(0)
  totalContacted  Int       @default(0)

  lastRunAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  job             Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  candidates      AgentCandidate[]

  @@index([userId, createdAt])
  @@index([status])
}

model AgentCandidate {
  id              String    @id @default(cuid())
  agentId         String
  resumeId        String?   // linked resume if exists in system
  name            String
  email           String?
  profileUrl      String?   // external profile link
  headline        String?   // current role / summary
  matchScore      Float?    // 0-100
  status          String    @default("pending") // pending, approved, rejected, contacted
  outreachSentAt  DateTime?
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  agent           Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  resume          Resume?   @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@index([agentId, status])
  @@index([agentId, createdAt])
}

/// GoHire interview records imported from CSV export
model GoHireInterview {
  id                    String    @id @default(cuid())
  gohireUserId          String                          // candidate UUID in GoHire
  candidateName         String                          // 候选人姓名
  candidateEmail        String?                         // 用户邮箱（登录名称）
  interviewDatetime     DateTime                        // 面试开始时间
  interviewEndDatetime  DateTime?                       // 面试结束时间
  duration              Int?                            // 面试时长 (minutes)
  videoUrl              String?   @db.Text              // gohire_interview_video_filepath
  recruiterName         String?                         // 招聘人员姓名
  recruiterEmail        String?                         // 招聘人员邮箱
  recruiterId           String?                         // gohire_recruiter_id
  jobTitle              String?                         // 职位名称
  jobDescription        String?   @db.Text              // 职位描述
  jobRequirements       String?   @db.Text              // 任职要求
  interviewRequirements String?   @db.Text              // 面试要求
  resumeUrl             String?   @db.Text              // 简历下载地址
  transcriptUrl         String?   @db.Text              // 面试记录下载地址
  parsedResumeText      String?   @db.Text              // Cached parsed resume markdown
  lastLoginAt           DateTime?                       // 最近登录时间
  invitedAt             DateTime?                       // 邀约时间
  transcript            String?   @db.Text              // Fetched/generated transcript
  evaluationData        Json?                           // Evaluation result JSON
  evaluationScore       Int?                            // Quick-access score (0-100)
  evaluationVerdict     String?                         // strong_hire, hire, weak_hire, no_hire
  evaluationShareToken  String?   @unique               // Share token for public evaluation report

  // Foreign key links to core entities (populated during CSV import pipeline)
  candidateUserId        String?                         // FK → User (candidate account)
  userId                 String?                         // FK → User (recruiter/owner)
  resumeId               String?                         // FK → Resume (parsed resume in TalentHub)
  jobId                  String?                         // FK → Job (linked job posting)
  resumeProcessingStatus String?   @default("pending")   // pending, processing, completed, failed, skipped
  resumeProcessingError  String?   @db.Text              // Error message if resume processing failed
  importBatchId          String?                         // Groups records from same CSV upload

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  candidateUser  User?    @relation("GoHireCandidateUser", fields: [candidateUserId], references: [id], onDelete: SetNull)
  recruiterUser  User?    @relation("GoHireRecruiterUser", fields: [userId], references: [id], onDelete: SetNull)
  resume         Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  job            Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([candidateName])
  @@index([candidateEmail])
  @@index([recruiterEmail])
  @@index([jobTitle])
  @@index([interviewDatetime])
  @@index([gohireUserId])
  @@index([evaluationScore])
  @@index([candidateUserId])
  @@index([userId])
  @@index([resumeId])
  @@index([jobId])
  @@index([importBatchId])
  @@index([resumeProcessingStatus])
}

model GoHireImportBatch {
  id                String   @id @default(cuid())
  adminUserId       String                          // Who triggered the import
  fileName          String?                         // Original CSV filename
  totalRows         Int                             // Total data rows in CSV
  phase1Completed   Boolean  @default(false)        // Sync phase done
  phase2Completed   Boolean  @default(false)        // Async resume processing done
  usersCreated      Int      @default(0)
  usersLinked       Int      @default(0)
  jobsCreated       Int      @default(0)
  jobsLinked        Int      @default(0)
  resumesCreated    Int      @default(0)
  resumesFailed     Int      @default(0)
  resumesPending    Int      @default(0)
  interviewsCreated Int      @default(0)
  interviewsUpdated Int      @default(0)
  interviewsSkipped Int      @default(0)
  errors            Json?                           // Array of {row, error}
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([adminUserId])
  @@index([createdAt])
}

model AgentAlexSession {
  id           String   @id @default(cuid())
  userId       String
  title        String   @default("New Chat")
  messages     Json     @default("[]")    // ChatMessage[]
  requirements Json     @default("{}")    // HiringRequirements
  linkedJobId  String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedJob    Job?     @relation(fields: [linkedJobId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
}

model Task {
  id            String    @id @default(cuid())
  userId        String    // assignee
  createdById   String?   // who/what created it (null = system)

  // Classification
  type          String    // evaluate_interview, review_evaluation, hiring_decision, review_matches, shortlist_candidates, send_interview_invite, follow_up_invitation, interview_reminder, run_matching, review_agent_candidates, publish_job, close_stale_job, stale_pipeline, sync_gohire_interviews, reparse_resume
  category      String    // pipeline, evaluation, sourcing, communication, admin
  assigneeType  String    @default("human") // human | agent

  // Content
  title         String
  description   String?   @db.Text
  actionUrl     String?   // deep link to relevant page
  actionLabel   String?   // button text for the primary action

  // Context links
  jobId              String?
  resumeId           String?
  interviewId        String?
  candidateId        String?
  matchingSessionId  String?
  agentId            String?
  hiringRequestId    String?

  // Priority & SLA
  priority      String    @default("medium") // critical, high, medium, low
  dueAt         DateTime?
  slaDeadline   DateTime?
  escalatedAt   DateTime?

  // Status
  status        String    @default("pending") // pending, in_progress, completed, dismissed, expired, auto_completed
  completedAt   DateTime?
  completedBy   String?   // userId or 'system'
  dismissReason String?
  result        Json?     // outcome data

  // Trigger
  triggerEvent  String    // what event spawned this
  triggerData   Json?     // event context snapshot
  isAutoGenerated Boolean @default(true)

  // Archive
  archivedAt    DateTime? // set 7 days after completed/dismissed

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user          User      @relation("TaskAssignee", fields: [userId], references: [id], onDelete: Cascade)
  createdBy     User?     @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  job           Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  resume        Resume?   @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  interview     Interview? @relation(fields: [interviewId], references: [id], onDelete: SetNull)
  notifications Notification[]

  @@index([userId, status])
  @@index([userId, priority])
  @@index([type, status])
  @@index([status, dueAt])
  @@index([jobId])
  @@index([interviewId])
  @@index([resumeId])
  @@index([archivedAt])
  @@index([createdAt])
}

model TaskAutomationRule {
  id                  String    @id @default(cuid())
  userId              String?   // null = global default
  taskType            String    @unique // maps to task type enum
  enabled             Boolean   @default(true)
  assigneeType        String    @default("human") // human | agent
  autoExecute         Boolean   @default(false) // for agent tasks: execute immediately?
  slaHours            Int?      // SLA deadline in hours
  priority            String    @default("medium") // default priority
  escalateAfterHours  Int?      // hours after creation to escalate
  emailNotify         Boolean   @default(false) // send email on creation?
  config              Json?     // extra type-specific config
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([taskType])
  @@index([userId])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String    // recipient
  taskId      String?   // linked task
  type        String    // task_created, task_overdue, task_escalated, task_completed
  title       String
  message     String?
  actionUrl   String?
  read        Boolean   @default(false)
  readAt      DateTime?
  emailSent   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([taskId])
}

model Contact {
  id              String    @id @default(cuid())
  userId          String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  jobTitle        String?
  contactType     String    @default("client")    // hiring_manager, client, vendor, reference
  companyId       String?
  notes           String?   @db.Text
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company         Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([contactType])
  @@index([companyId])
  @@index([createdAt])
}

model Company {
  id              String    @id @default(cuid())
  userId          String
  name            String
  industry        String?
  size            String?               // e.g. "50-200", "1000+"
  location        String?
  website         String?
  notes           String?   @db.Text
  openJobs        Int       @default(0)
  totalPlaced     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts        Contact[]

  @@index([userId])
  @@index([name])
  @@index([createdAt])
}
