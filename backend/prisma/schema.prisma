// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  company       String?
  avatar        String?
  role          String    @default("user") // 'user' or 'admin'
  provider      String?   // 'email', 'google', 'github', 'linkedin'
  providerId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Subscription / Stripe
  stripeCustomerId    String?   @unique
  subscriptionTier    String    @default("free") // free, startup, business, custom
  subscriptionStatus  String    @default("active") // active, past_due, canceled
  subscriptionId      String?
  currentPeriodEnd    DateTime?
  trialEnd            DateTime?
  interviewsUsed      Int       @default(0)
  resumeMatchesUsed   Int       @default(0)
  topUpBalance        Float     @default(0)
  customMaxInterviews Int?      // Admin override for max interviews (null = use plan default)
  customMaxMatches    Int?      // Admin override for max matches (null = use plan default)
  
  hiringRequests  HiringRequest[]
  sessions        Session[]
  hiringSessions  HiringSession[]
  apiKeys         ApiKey[]
  usageRecords    ApiUsageRecord[]
  apiRequestLogs  ApiRequestLog[]
  llmCallLogs     LLMCallLog[]
  topUpRecords    TopUpRecord[]
  resumes         Resume[]
  adminAdjustmentsReceived  AdminAdjustment[] @relation("AdminAdjustmentsReceived")
  adminAdjustmentsMade      AdminAdjustment[] @relation("AdminAdjustmentsMade")
  atsIntegrations ATSIntegration[]
  jobs            Job[]
  interviews         Interview[]
  matchingSessions   MatchingSession[]

  @@index([email])
  @@index([provider, providerId])
  @@index([createdAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model HiringRequest {
  id              String   @id @default(cuid())
  userId          String
  title           String
  requirements    String   @db.Text
  jobDescription  String?  @db.Text
  status                String   @default("active") // active, paused, closed
  webhookUrl            String?
  intelligenceData      Json?
  intelligenceUpdatedAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidates     Candidate[]
  resumeJobFits  ResumeJobFit[]
  jobs           Job[]
  interviews     Interview[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([userId, createdAt])
}

model Candidate {
  id               String   @id @default(cuid())
  hiringRequestId  String
  name             String
  email            String
  resumeText       String   @db.Text
  matchScore       Int?
  status           String   @default("pending") // pending, screening, interviewed, shortlisted, rejected
  evaluationReport Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  externalAtsId       String?
  externalAtsProvider String?

  hiringRequest HiringRequest @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)

  @@index([hiringRequestId])
  @@index([status])
  @@index([email])
  @@index([hiringRequestId, status])
  @@index([hiringRequestId, matchScore])
  @@index([externalAtsId])
}

model HiringSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  messages  Json     @default("[]")
  status    String   @default("active") // active, completed, archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([userId, updatedAt])
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  key         String    @unique
  prefix      String    // First 8 chars for display (rh_xxxx...)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  scopes      String[]  @default(["read", "write"])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageRecords ApiUsageRecord[]
  requestLogs  ApiRequestLog[]

  @@index([key])
  @@index([userId])
}

model ApiUsageRecord {
  id               String   @id @default(cuid())
  userId           String
  apiKeyId         String?
  requestId        String?
  endpoint         String
  method           String
  statusCode       Int      @default(200)
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  cost             Float    @default(0)
  model            String?
  provider         String?
  durationMs       Int      @default(0)
  createdAt        DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([apiKeyId])
  @@index([createdAt])
  @@index([endpoint])
  @@index([userId, createdAt])
  @@index([apiKeyId, createdAt])
}

model ApiRequestLog {
  id               String   @id @default(cuid())
  requestId        String?
  userId           String?
  apiKeyId         String?
  endpoint         String
  method           String
  module           String
  apiName          String
  statusCode       Int      @default(200)
  durationMs       Int      @default(0)
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  llmCalls         Int      @default(0)
  cost             Float    @default(0)
  provider         String?
  model            String?
  ipAddress        String?
  userAgent        String?
  requestPayload   Json?
  responsePayload  Json?
  createdAt        DateTime @default(now())

  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiKey     ApiKey?      @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  llmCallLog LLMCallLog[]

  @@index([requestId])
  @@index([userId])
  @@index([apiKeyId])
  @@index([createdAt])
  @@index([endpoint])
  @@index([module])
  @@index([apiName])
  @@index([provider])
  @@index([model])
  @@index([userId, createdAt])
  @@index([module, createdAt])
  @@index([apiName, createdAt])
}

model LLMCallLog {
  id               String   @id @default(cuid())
  requestId        String?
  apiRequestLogId  String?
  userId           String?
  endpoint         String
  module           String
  provider         String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  cost             Float    @default(0)
  durationMs       Int      @default(0)
  createdAt        DateTime @default(now())

  apiRequestLog ApiRequestLog? @relation(fields: [apiRequestLogId], references: [id], onDelete: SetNull)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([apiRequestLogId])
  @@index([userId])
  @@index([createdAt])
  @@index([endpoint])
  @@index([module])
  @@index([provider])
  @@index([model])
  @@index([module, createdAt])
}

model TopUpRecord {
  id                  String   @id @default(cuid())
  userId              String
  stripeSessionId     String   @unique  // Stripe Checkout Session ID for idempotency
  stripePaymentIntent String?  @unique  // Stripe PaymentIntent ID
  amountCents         Int
  amountDollars       Float
  status              String   @default("pending") // pending, completed, failed
  creditedAt          DateTime?
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeSessionId])
  @@index([stripePaymentIntent])
  @@index([userId, createdAt])
}

model AdminAdjustment {
  id          String   @id @default(cuid())
  userId      String
  adminId     String
  type        String   // "balance", "usage_interview", "usage_match", "subscription"
  amount      Float?
  oldValue    String?
  newValue    String?
  reason      String
  createdAt   DateTime @default(now())

  user  User @relation("AdminAdjustmentsReceived", fields: [userId], references: [id], onDelete: Cascade)
  admin User @relation("AdminAdjustmentsMade", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([adminId])
  @@index([createdAt])
}

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([key])
}

model Resume {
  id              String    @id @default(cuid())
  userId          String
  name            String
  email           String?
  phone           String?
  currentRole     String?
  experienceYears String?
  resumeText      String    @db.Text
  parsedData      Json?
  insightData     Json?
  jobFitData      Json?
  fileName        String?
  fileSize        Int?
  fileType        String?
  contentHash     String?
  status          String    @default("active")
  source          String    @default("upload")
  tags            String[]  @default([])
  notes           String?   @db.Text
  preferences     Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeJobFits   ResumeJobFit[]
  jobMatches      JobMatch[]

  @@unique([userId, contentHash])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, status, createdAt])
  @@index([name])
  @@index([contentHash])
  @@index([createdAt])
}

model ResumeJobFit {
  id               String   @id @default(cuid())
  resumeId         String
  hiringRequestId  String
  fitScore         Int?
  fitGrade         String?
  fitData          Json?
  pipelineStatus   String   @default("matched") // matched, shortlisted, rejected, invited
  invitedAt        DateTime?
  inviteData       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  resume           Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  hiringRequest    HiringRequest  @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)

  @@unique([resumeId, hiringRequestId])
  @@index([resumeId])
  @@index([hiringRequestId])
  @@index([fitScore])
  @@index([pipelineStatus])
  @@index([hiringRequestId, pipelineStatus])
  @@index([hiringRequestId, fitScore])
}

model Job {
  id              String    @id @default(cuid())
  userId          String
  hiringRequestId String?
  title           String
  department      String?
  location        String?
  workType        String?   // remote, hybrid, onsite
  employmentType  String?   // full-time, part-time, contract, internship
  experienceLevel String?   // entry, mid, senior, lead, executive
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  String?   @default("USD")
  companyName          String?
  description          String?   @db.Text
  qualifications       String?   @db.Text   // 任职要求
  hardRequirements     String?   @db.Text   // 硬性要求
  requirements         Json?     // { mustHave: [], niceToHave: [] }
  parsedData           Json?     // AI-parsed JD cache
  salaryPeriod         String?   @default("monthly") // monthly, yearly
  locations            Json?     // Array of { country, city }
  interviewMode        String?   @default("standard") // standard, question_bank
  passingScore         Int?      @default(60)  // 20-80
  interviewLanguage    String?   @default("en")
  interviewDuration    Int?      @default(30)  // minutes: 15,30,45,60
  interviewRequirements String?  @db.Text  // 面试要求
  evaluationRules      String?   @db.Text  // 评估规则
  status               String    @default("draft") // draft, open, paused, closed, filled
  publishedAt     DateTime?
  closedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  hiringRequest     HiringRequest?    @relation(fields: [hiringRequestId], references: [id], onDelete: SetNull)
  jobMatches        JobMatch[]
  matchingSessions  MatchingSession[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([userId, createdAt])
}

model JobMatch {
  id          String    @id @default(cuid())
  jobId       String
  resumeId    String
  score       Int?
  grade       String?   // A+, A, B+, B, C, D, F
  matchData   Json?     // Full ResumeMatchAgent output
  status      String    @default("new") // new, reviewed, shortlisted, rejected, invited
  reviewedAt  DateTime?
  reviewedBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume      Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([jobId, resumeId])
  @@index([jobId])
  @@index([resumeId])
  @@index([score])
  @@index([status])
  @@index([jobId, score])
}

model Interview {
  id              String    @id @default(cuid())
  userId          String
  jobId           String?
  resumeId        String?
  hiringRequestId String?
  candidateName   String
  candidateEmail  String?
  jobTitle        String?
  jobDescription  String?   @db.Text
  resumeText      String?   @db.Text
  status          String    @default("scheduled") // scheduled, in_progress, completed, cancelled, expired
  type            String    @default("ai_video")  // ai_video, ai_audio, ai_text
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  duration        Int?      // seconds
  accessToken     String?   @unique // unique token for candidate to join
  roomId          String?   // LiveKit room ID
  transcript      Json?     // Array of { role, content, timestamp }
  recordingUrl    String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  hiringRequest   HiringRequest? @relation(fields: [hiringRequestId], references: [id], onDelete: SetNull)
  evaluation      InterviewEvaluation?

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([accessToken])
  @@index([userId, createdAt])
  @@index([hiringRequestId])
  @@index([resumeId])
}

model InterviewEvaluation {
  id              String    @id @default(cuid())
  interviewId     String    @unique
  overallScore    Int?
  grade           String?
  verdict         String?   // strong_hire, hire, lean_hire, lean_no_hire, no_hire
  evaluationData  Json?     // Full evaluation agent output
  summary         String?   @db.Text
  strengths       Json?     // string[]
  weaknesses      Json?     // string[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@index([overallScore])
  @@index([verdict])
}

model ATSIntegration {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String   // "greenhouse" | "lever" | "ashby" | "bamboohr" | "workable"
  credentials   String   // encrypted JSON: { apiKey, subdomain, etc. }
  isActive      Boolean  @default(true)
  syncEnabled   Boolean  @default(true)
  lastSyncAt    DateTime?
  config        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  webhookDeliveries WebhookDelivery[]
  syncLogs          ATSSyncLog[]

  @@unique([userId, provider])
  @@index([userId])
}

model ATSSyncLog {
  id              String   @id @default(cuid())
  integrationId   String
  integration     ATSIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  direction       String   // "inbound" | "outbound"
  entityType      String   // "job" | "candidate" | "application"
  entityId        String?
  externalId      String?
  status          String   // "success" | "failed" | "skipped"
  error           String?
  payload         Json?
  createdAt       DateTime @default(now())

  @@index([integrationId])
  @@index([createdAt])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  integrationId   String?
  integration     ATSIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  hiringRequestId String?
  event           String
  url             String
  payload         Json
  status          String   // "pending" | "delivered" | "failed"
  statusCode      Int?
  attempts        Int      @default(0)
  maxAttempts     Int      @default(5)
  lastAttemptAt   DateTime?
  nextRetryAt     DateTime?
  response        String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([status, nextRetryAt])
  @@index([hiringRequestId])
}

model MatchingSession {
  id              String    @id @default(cuid())
  userId          String
  jobId           String
  title           String?
  status          String    @default("running") // running, completed, failed

  // Configuration snapshot
  config          Json      // { resumeIds[], preFilter: { locations?, jobTypes?, freeText? } }

  // Pre-filter results
  preFilterModel  String?
  preFilterResult Json?     // { passedIds[], excluded: [{ resumeId, reason }], durationMs }

  // Results summary
  totalResumes    Int       @default(0)
  totalFiltered   Int       @default(0)
  totalMatched    Int       @default(0)
  totalFailed     Int       @default(0)
  avgScore        Float?
  topGrade        String?

  // Cost tracking
  totalCost       Float     @default(0)
  totalTokens     Int       @default(0)
  totalLLMCalls   Int       @default(0)

  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([jobId])
}
