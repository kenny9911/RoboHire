{
  "name": "robohire-api",
  "version": "1.0.0",
  "description": "AI-Powered Recruitment APIs",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently --kill-others --kill-signal SIGINT \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:agent\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:agent": "npm run agent:start --workspace=backend",
    "build": "npm run build --workspace=backend && npm run build --workspace=frontend",
    "start": "npm run start --workspace=backend",
    "restart": "./scripts/restart.sh",
    "stop": "./scripts/stop.sh",
    "services:start": "./scripts/start.sh",
    "services:stop": "./scripts/stop.sh",
    "services:restart": "./scripts/restart.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prisma": "6.9.0"
  },
  "dependencies": {
    "@prisma/client": "6.9.0",
    "multer": "^2.0.2"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "^0.27.2"
  }
}
